{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Image to LEGO Converter",
  "version": "0.1.0",
  "identifier": "com.aakash.image-to-lego-desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Image to LEGO Converter",
        "width": 1250,
        "height": 1040,
        "minWidth": 1000,
        "minHeight": 800,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/cli_convert"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
